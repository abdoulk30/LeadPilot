# Copy to .env and fill in real values locally. Never commit .env.
# See leadpilot-docs/commands/README.md and
# leadpilot-docs/security/secrets-rotation-runbook.md.

# Google Sheets API — for fetch_all_leads
GOOGLE_SHEETS_API_KEY=
# or, if using OAuth client credentials instead of an API key:
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Google Voice API / call log source — for get_contact_history
# NOTE: access model unverified — see leadpilot-docs/testing/known-issues-log.md Issue 001
GOOGLE_VOICE_API_KEY=

# Google Drive API — for verify_drive_contents
GOOGLE_DRIVE_API_KEY=

# Slack Web API — for dispatch_slack_handoff
SLACK_BOT_TOKEN=
SLACK_HANDOFF_CHANNEL_IDS=

# Run schedule / environment
NODE_ENV=development
