# Copy to .env.local and fill in real values locally (this repo's
# config loader reads .env.local, falling back to .env). Never commit
# either. See leadpilot-docs/commands/README.md and
# leadpilot-docs/security/secrets-rotation-runbook.md.
#
# For DATABASE_URL specifically, local dev doesn't need real Neon
# credentials — run `scripts/devdb.sh init && scripts/devdb.sh start`
# then `scripts/devdb.sh url` to get a working local value.
#
# Stack locked by Decision 022 (leadpilot-docs/decisions/README.md):
# Python + Claude Agent SDK, FastAPI, Postgres via Neon, Render.

# The agent loop (leadpilot.agent_loop, PRD v1.06 system prompt) —
# Anthropic Messages API via the anthropic SDK (Decision 037).
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-opus-4-8 (config.py).
# ANTHROPIC_MODEL=claude-opus-4-8

# Neon Postgres connection string — the shared state store (contact
# history log + approval-gate `stage` field + dedup/run-lock), read
# and written by both the Web Service and the Cron Job.
# See leadpilot-docs/architecture/state-schema.md.
DATABASE_URL=

# SUPERSEDED 2026-07-11 (leadpilot-docs Decision 026) — kept working
# for now because the merged Step 1 GoogleSheetsConnector still reads
# these two vars for local dev. Do not build anything new against
# them. The go-forward model is per-rep OAuth (GOOGLE_OAUTH_CLIENT_ID/
# SECRET below, drive.file scope) — no shared service account, no
# static admin-configured sheet list. Remove these two once Step 2
# reworks the connector (see leadpilot-docs/mvp/README.md Step 2).
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=
# JSON mapping of source_id -> Google Sheet ID, e.g.
# {"inbound_sheet_a": "1Byr..."}
GOOGLE_SHEETS_SOURCES={}

# Google OAuth client — covers Sheets, Drive, AND Gmail as of Decision
# 026 (reversed 2026-07-11, supersedes the service-account plan
# above). Sheets/Drive use the drive.file scope: each rep does a
# one-time "Connect Google Account" consent, then picks specific
# sheets/folders via the Google Picker (GOOGLE_PICKER_API_KEY below) —
# nothing is pre-shared to a standing identity, and LeadPilot stores
# each rep's own refresh token in Postgres (rep_google_credentials,
# see leadpilot-docs/architecture/state-schema.md), not an env var.
# Gmail consent (send_lead_email, feeds search_communications) uses
# this same client. Not yet built (Step 2).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Client-side key for the Google Picker widget (Decision 026) — lets a
# rep select which sheets/folders to grant LeadPilot. Lower sensitivity
# than the OAuth client secret above (exposed to the browser by
# design), but still don't commit a real value. Not yet built (Step 2).
GOOGLE_PICKER_API_KEY=

# Where Google redirects after a rep completes the OAuth consent —
# must exactly match a URI registered on the OAuth client in Google
# Cloud Console. Local dev: http://localhost:8000/auth/google/callback
# (http:// is fine for localhost specifically — Google's HTTPS
# requirement is waived for localhost/127.0.0.1). A second URI for the
# real prod domain needs to be added to the same OAuth client once
# deployed, not swapped in — both coexist.
GOOGLE_OAUTH_REDIRECT_URI=

# Fernet key encrypting rep_google_credentials.refresh_token_encrypted
# (leadpilot/crypto.py) — every rep's Google refresh token is stored
# encrypted at the application layer, never in plaintext. Generate
# with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Rotating this key requires re-encrypting every stored token and
# forcing every rep to reconnect (see
# leadpilot-docs/security/secrets-rotation-runbook.md) — treat a
# compromise of this key as an incident, not a routine rotation.
CREDENTIAL_ENCRYPTION_KEY=

# Twilio — send_lead_text and the SMS half of search_communications.
# No Google Voice credential exists or is used anywhere in this
# project — see leadpilot-docs/testing/known-issues-log.md Issue 001
# (resolved: Google Voice has no API and is not used by any tool).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Slack Web API — chat.postMessage, for dispatch_slack_handoff
# (completion_handoff / info_request / urgent_callback_request)
SLACK_BOT_TOKEN=
SLACK_HANDOFF_CHANNEL_IDS=

# Signs/validates authenticated rep sessions (Decision 013 access
# control requirement). Resolved 2026-07-09: email/password with our
# own DB-backed sessions (leadpilot/models/rep.py, leadpilot/auth.py),
# not Google OAuth — keeps rep login independent of the Google Cloud
# project from Step 0.
REP_AUTH_SESSION_SECRET=

# Run environment
ENVIRONMENT=development

# Note what's deliberately NOT here: there is no APPROVAL_TOKEN_SECRET
# or equivalent. Decision 021 resolved the rep-approval mechanism as a
# conditional database update on the contact-history log's own `stage`
# column — no signed or opaque token object exists to configure.
