# Copy to .env.local and fill in real values locally (this repo's
# config loader reads .env.local, falling back to .env). Never commit
# either. See leadpilot-docs/commands/README.md and
# leadpilot-docs/security/secrets-rotation-runbook.md.
#
# For DATABASE_URL specifically, local dev doesn't need real Neon
# credentials — run `scripts/devdb.sh init && scripts/devdb.sh start`
# then `scripts/devdb.sh url` to get a working local value.
#
# Stack locked by Decision 022 (leadpilot-docs/decisions/README.md):
# Python + Claude Agent SDK, FastAPI, Postgres via Neon, Render.

# Claude Agent SDK — runs the tool-calling loop (PRD v1.04 system prompt)
ANTHROPIC_API_KEY=

# Neon Postgres connection string — the shared state store (contact
# history log + approval-gate `stage` field + dedup/run-lock), read
# and written by both the Web Service and the Cron Job.
# See leadpilot-docs/architecture/state-schema.md.
DATABASE_URL=

# Google Sheets access for fetch_all_leads/update_lead_sheet — a
# service account, not the OAuth client below. Rationale (changed
# 2026-07-09, see leadpilot/connectors/google_sheets.py docstring):
# this runs inside an unattended hourly Cron Job with no human present
# to click through an OAuth consent screen, and no per-rep identity is
# relevant to reading/writing a shared business spreadsheet. Create
# one for free at console.cloud.google.com (Service Account -> JSON
# key), enable the Sheets API, and share each source spreadsheet with
# the key's client_email as Editor.
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=
# JSON mapping of source_id -> Google Sheet ID, e.g.
# {"inbound_sheet_a": "1Byr..."}
GOOGLE_SHEETS_SOURCES={}

# Google OAuth client — for Gmail specifically (send_lead_email,
# feeds search_communications). Genuinely different from Sheets
# access above: sending as a specific rep's own Gmail account needs
# real per-rep consent, not a service account. Not yet built (Step 2).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Twilio — send_lead_text and the SMS half of search_communications.
# No Google Voice credential exists or is used anywhere in this
# project — see leadpilot-docs/testing/known-issues-log.md Issue 001
# (resolved: Google Voice has no API and is not used by any tool).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Slack Web API — chat.postMessage, for dispatch_slack_handoff
# (completion_handoff / info_request / urgent_callback_request)
SLACK_BOT_TOKEN=
SLACK_HANDOFF_CHANNEL_IDS=

# Signs/validates authenticated rep sessions (Decision 013 access
# control requirement). Resolved 2026-07-09: email/password with our
# own DB-backed sessions (leadpilot/models/rep.py, leadpilot/auth.py),
# not Google OAuth — keeps rep login independent of the Google Cloud
# project from Step 0.
REP_AUTH_SESSION_SECRET=

# Run environment
ENVIRONMENT=development

# Note what's deliberately NOT here: there is no APPROVAL_TOKEN_SECRET
# or equivalent. Decision 021 resolved the rep-approval mechanism as a
# conditional database update on the contact-history log's own `stage`
# column — no signed or opaque token object exists to configure.
